# Optional: enables the one-line "why it matters" notes in scripts/fetch-feeds.mjs.
# Without it, the pipeline still works - items just show the RSS excerpt only.
# ANTHROPIC_API_KEY=sk-ant-...

# Set after Google AdSense approval to switch ad slots from placeholders to real ads.
# NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX

# Canonical site URL used in sitemap.xml and metadata. Defaults to the
# ai-news-hub.vercel.app placeholder if unset.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
